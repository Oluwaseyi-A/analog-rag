# === LLM Provider (LiteLLM routes to whichever is set) ===
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Default models (LiteLLM format)
SUPERAGENT_MODEL=claude-sonnet-4-6
RESEARCH_AGENT_MODEL=claude-sonnet-4-6
SPICE_AGENT_MODEL=claude-sonnet-4-6

# === Embeddings ===
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# === Vector Store (ChromaDB) ===
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NETLIST=analog_netlists
CHROMA_COLLECTION_GRAPH=analog_graphs
CHROMA_COLLECTION_BEHAVIOR=analog_behavior

# === Data paths (inside container) ===
RAG_DATA_PATH=/data/rag_data
PDK_ROOT=/data/PDK

# === Storage ===
DB_PATH=/app/data/measurements.db
GRAPH_STORE_PATH=/app/data/graphs
GIN_WEIGHTS_PATH=/app/data/gin_weights.pt

# === ngspice ===
NGSPICE_BIN=/usr/bin/ngspice
